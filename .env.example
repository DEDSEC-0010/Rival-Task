# --- Backend ---
# PostgreSQL connection string (async driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/tasks

# JWT signing — replace with a long random string in production
JWT_SECRET=change-me-in-production-please-32-chars-min
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=1440

# Cookie settings
COOKIE_NAME=tm_token
# Set COOKIE_SECURE=true behind HTTPS in production
COOKIE_SECURE=false
# Use "none" when the frontend lives on a different origin than the backend
# (e.g. Render frontend + backend on separate subdomains). Requires COOKIE_SECURE=true.
# Use "lax" for same-site local dev.
COOKIE_SAMESITE=lax

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# Environment label
ENVIRONMENT=development

# --- Frontend ---
# Base URL of the backend API as visible to the browser
NEXT_PUBLIC_API_URL=http://localhost:8000
